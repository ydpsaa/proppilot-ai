{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ],
  "rewrites": [
    { "source": "/live",     "destination": "/live.html"      },
    { "source": "/signal",   "destination": "/signal.html"    },
    { "source": "/bot",      "destination": "/bot.html"       },
    { "source": "/analytics","destination": "/analytics.html" }
  ]
}
